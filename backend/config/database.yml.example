default: &default
  adapter: postgresql
  encoding: unicode
  pool: <%= ENV.fetch("RAILS_MAX_THREADS") { 5 } %>
  username: <%= ENV.fetch("POSTGRES_USER") { "postgres" } %>
  password: <%= ENV.fetch("POSTGRES_PASSWORD") { "postgres" } %>
  host: <%= ENV.fetch("POSTGRES_HOST") { "localhost" } %>

development:
  <<: *default
  database: larmodular_development

test:
  <<: *default
  database: larmodular_test

production:
  <<: *default
  database: larmodular_production
  username: larmodular
  password: <%= ENV["LARMODULAR_DATABASE_PASSWORD"] %>
